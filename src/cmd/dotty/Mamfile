meta dotty %.sh>% dotty.sh dotty
prev dotty.sh
exec - case static,port:$OPTIND:$RANDOM in
exec - ?*:*:*|*::*|*:*:$RANDOM)
exec - ;;
exec - *) if ENV= LC_ALL=C x= $SHELL -nc '[[ a || b ]] && : ${list[level]}  !(pattern)' 2>/dev/null
exec - then if grep '### .*archaic.* ###' >/dev/null
exec - then : dotty contains archaic constructs :
exec - else ENV= LC_ALL=C $SHELL -n dotty.sh
exec - fi
exec - fi
exec - ;;
exec - esac
exec - case '${mam_cc_SHELLMAGIC}' in
exec - "") case 0 in
exec - 0) cp dotty.sh dotty
exec - ;;
exec - *) {
exec - i=`(read x; echo $x) < dotty.sh`
exec - case $i in
exec - '#!'*|*'||'*|':'*|'":"'*|"':'"*) echo "$i" ;;
exec - esac
exec - cat - dotty.sh <<'!'
exec -
exec - !
exec - } > dotty
exec - ;;
exec - esac
exec - ;;
exec - *) cat - dotty.sh > dotty <<'!'
exec - ${mam_cc_SHELLMAGIC}
exec -
exec - !
exec - ;;
exec - esac
exec - silent test -w dotty -a -x dotty || chmod u+w,+x dotty
done dotty generated
